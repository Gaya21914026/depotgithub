pipeline {
    agent any

    environment {
        IMAGE_NAME = 'myapp-image'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('clone git') {
            steps {
                sh 'rm -rf depotgithub'
                sh 'git clone https://github.com/Gaya21914026/depotgithub.git'
            }
        }


        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME} .'
            }
        }

      }
}